# Example nginx configuration for Catastrophe Companion
# Place this in /etc/nginx/sites-available/catastrophe-companion
# Then symlink: sudo ln -s /etc/nginx/sites-available/catastrophe-companion /etc/nginx/sites-enabled/

server {
    listen 80;
    listen [::]:80;
    
    server_name 3.20.223.76;  # Replace with your domain when you have one
    
    root /var/www/catastrophe-companion;
    index index.html;
    
    location / {
        try_files $uri $uri/ /index.html;
    }

    # index.html and flutter_bootstrap.js must NEVER be cached
    # These are the entry points that reference all other (hashed) files
    location = /index.html {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma "no-cache";
        add_header Expires "0";
    }

    location = /flutter_bootstrap.js {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    # flutter_service_worker.js must not be cached either
    location = /flutter_service_worker.js {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    # Cache static assets (fonts, images) — these rarely change
    location ~* \.(png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # JS/CSS files — Flutter build output uses content hashes in filenames,
    # so they can be cached long-term. main.dart.js is the exception but
    # flutter_bootstrap.js (uncached above) always points to the right version.
    location ~* \.(js|css)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
    
    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    
    # Gzip compression
    gzip on;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/xml+rss application/json;
    gzip_vary on;
    
    # Disable access to hidden files
    location ~ /\. {
        deny all;
    }
}